---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

// タグ集計の定数
const INITIAL_TAG_COUNT = 0;
const INCREMENT_COUNT = 1;
const TAG_COUNT_INDEX = 1;
const TAG_NAME_INDEX = 0;

const posts = await getCollection("blog");

const tagCounts = posts.reduce(
  (acc, post) => {
    post.data.tags.forEach((tag) => {
      const normalizedTag = tag.toLowerCase();
      acc[normalizedTag] =
        (acc[normalizedTag] || INITIAL_TAG_COUNT) + INCREMENT_COUNT;
    });
    return acc;
  },
  {} as Record<string, number>,
);

const sortedTags = Object.entries(tagCounts).toSorted((a, b) => {
  if (b[TAG_COUNT_INDEX] !== a[TAG_COUNT_INDEX]) {
    return b[TAG_COUNT_INDEX] - a[TAG_COUNT_INDEX];
  }
  return a[TAG_NAME_INDEX].localeCompare(b[TAG_NAME_INDEX]);
});
---

<Layout title="Tags | Blog | HALQME">
  <section aria-labelledby="tags-title">
    <div class="mb-8 flex items-start justify-between">
      <h1
        id="tags-title"
        class="text-headline mb-0 flex items-center gap-3"
        transition:animate="slide"
      >
        <span class="i-lucide:tags" aria-hidden="true"></span>
        Tags
      </h1>
      <a href="/blog" class="btn-ghost text-sm">
        <span class="i-lucide:pen-tool" aria-hidden="true"></span>
        Blog
      </a>
    </div>

    {
      sortedTags.length === 0 ? (
        <p class="text-body">タグがありません。</p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {sortedTags.map(([tag, count]) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag tag-hover group">
              <div
                class="i-lucide:tag text-light group-hover:text-muted transition-colors"
                aria-hidden="true"
              />
              <span class="text-subtle">{tag}</span>
              <span class="border-base text-muted ml-1 border-l pl-1.5 text-xs">
                {count}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Layout>
