---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  activeTag?: string | null;
}

const { post, activeTag = null } = Astro.props;

const isActiveTag = (tag: string) =>
  activeTag && activeTag.toLowerCase() === tag.toLowerCase();
---

<article
  class="card-interactive group relative flex flex-col"
  transition:name={`blog-card-${post.id}`}
>
  <div class="flex-1 p-6">
    <h2 class="text-headline relative mb-2">
      <a
        href={`/blog/${post.id}/`}
        class="decoration-2 underline-offset-4 group-hover:underline"
        transition:name={`blog-title-${post.id}`}
      >
        <span class="absolute inset-0 z-10" aria-hidden="true"></span>
        {post.data.title}
      </a>
    </h2>
    <div class="text-label before:content-empty before:i-lucide:calendar mb-3">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString("ja-JP")}
      </time>
    </div>
    {
      post.data.description && (
        <p class="text-body mb-4 line-clamp-3">{post.data.description}</p>
      )
    }
  </div>
  {
    post.data.tags && post.data.tags.length > 0 && (
      <div class="relative z-20 px-6 pt-0 pb-6">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a
              href={`/blog/tags/${isActiveTag(tag) ? "" : tag.toLowerCase()}`}
              class:list={[
                "tag before:content-empty before:i-lucide:tag text-xs",
                isActiveTag(tag)
                  ? "border-dark bg-primary text-secondary shadow-card-subtle"
                  : "",
              ]}
              aria-current={isActiveTag(tag) ? "page" : undefined}
            >
              {tag}
            </a>
          ))}
        </div>
      </div>
    )
  }
</article>
