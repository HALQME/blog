---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  activeTag?: string | null;
}

const { post, activeTag = null } = Astro.props;

const isActiveTag = (tag: string) =>
  activeTag && activeTag.toLowerCase() === tag.toLowerCase();
---

<article class="card-interactive group relative flex flex-col">
  <div class="flex-1 p-6">
    <h2 class="text-headline mb-2" transition:name={`title-${post.id}`}>
      <a
        href={`/blog/${post.id}/`}
        class="decoration-2 underline-offset-4 group-hover:underline"
      >
        <span class="absolute inset-0 z-10" aria-hidden="true"></span>
        {post.data.title}
      </a>
    </h2>
    <div class="text-label mb-3">
      <div class="i-lucide:calendar" aria-hidden="true"></div>
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString("ja-JP")}
      </time>
    </div>
    {
      post.data.description && (
        <p class="text-body mb-4 line-clamp-3">{post.data.description}</p>
      )
    }
  </div>
  {
    post.data.tags && post.data.tags.length > 0 && (
      <div class="relative z-20 px-6 pt-0 pb-6">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a
              href={`/tags/${isActiveTag(tag) ? "" : tag.toLowerCase()}`}
              class:list={[
                "tag text-xs",
                isActiveTag(tag)
                  ? "border-dark bg-primary text-secondary shadow-card-subtle"
                  : "",
              ]}
              aria-current={isActiveTag(tag) ? "page" : undefined}
            >
              <div class="i-lucide:tag" aria-hidden="true" />
              {tag}
            </a>
          ))}
        </div>
      </div>
    )
  }
</article>
