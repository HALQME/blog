---
export interface Props {
  path: string;
  title: string;
}

const { path, title } = Astro.props;

const url = `${Astro.site}${path}`;

const TOOLTIP_DURATION_MS = 2000;

const shareItems = [
  {
    ariaLabel: "Xでシェア",
    href: `https://twitter.com/intent/tweet?text=${encodeURIComponent(title + " " + url)}`,
    icon: "i-simple-icons:x",
    key: "x",
    label: "Xでシェア",
  },
  {
    ariaLabel: "Blueskyでシェア",
    href: `https://bsky.app/intent/compose?text=${encodeURIComponent(title + " " + url)}`,
    icon: "i-simple-icons:bluesky",
    key: "bluesky",
    label: "Blueskyでシェア",
  },
  {
    ariaLabel: "Mastodonでシェア",
    href: `https://mastodonshare.com/?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`,
    icon: "i-simple-icons:mastodon",
    key: "mastodon",
    label: "Mastodonでシェア",
  },
  {
    ariaLabel: "はてなブックマークに追加",
    href: `https://b.hatena.ne.jp/entry/s/${Astro.site?.hostname}${path}${encodeURIComponent(title)}#bbutton`,
    icon: "i-simple-icons:hatenabookmark",
    key: "hatena",
    label: "はてブに追加",
  },
  {
    ariaLabel: "Facebookでシェア",
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
    icon: "i-simple-icons:facebook",
    key: "facebook",
    label: "Facebookでシェア",
  },
];
---

<div class="share-buttons flex flex-wrap items-center gap-2">
  {
    shareItems.map((item) => (
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn group relative inline-flex h-11 w-11 items-center justify-center"
        aria-label={item.ariaLabel}
      >
        <span
          class={`before:content-empty before:text-base ${item.icon}`}
          aria-hidden="true"
        />
        <span
          class="tooltip absolute -bottom-8 left-1/2 -translate-x-1/2 rounded-xs bg-neutral-800 px-2 py-1 text-xs whitespace-nowrap text-white opacity-0 transition-opacity group-hover:opacity-100 dark:bg-neutral-200 dark:text-black"
          aria-hidden="true"
        >
          {item.label}
        </span>
      </a>
    ))
  }

  <button
    type="button"
    class="share-btn copy-btn group relative inline-flex h-11 w-11 items-center justify-center"
    data-url={url}
    aria-label="URLをコピー"
  >
    <span
      class="before:content-empty before:i-lucide:link before:text-base"
      aria-hidden="true"></span>
    <span
      class="copy-tooltip absolute -bottom-8 left-1/2 -translate-x-1/2 rounded-xs bg-green-600 px-2 py-1 text-xs whitespace-nowrap text-white opacity-0 transition-opacity"
      aria-hidden="true"
    >
      コピー完了！
    </span>
    <span
      class="default-tooltip absolute -bottom-8 left-1/2 -translate-x-1/2 rounded-xs bg-neutral-800 px-2 py-1 text-xs whitespace-nowrap text-white opacity-0 transition-opacity group-hover:opacity-100 dark:bg-neutral-200 dark:text-black"
      aria-hidden="true"
    >
      URLをコピー
    </span>
  </button>
</div>

<div role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<script>
  const TOOLTIP_DURATION_MS = 2000;

  const initCopyButtons = () => {
    const copyButtons = document.querySelectorAll(".copy-btn");

    copyButtons.forEach((button) => {
      if (button.hasAttribute("data-copy-initialized")) {
        return;
      }
      button.setAttribute("data-copy-initialized", "true");

      button.addEventListener("click", async () => {
        const url = button.getAttribute("data-url");
        if (!url) {
          return;
        }

        try {
          await navigator.clipboard.writeText(url);

          const copyTooltip = button.querySelector(".copy-tooltip");
          const defaultTooltip = button.querySelector(".default-tooltip");

          if (copyTooltip && defaultTooltip) {
            defaultTooltip.classList.add("opacity-0");
            copyTooltip.classList.remove("opacity-0");

            setTimeout(() => {
              copyTooltip.classList.add("opacity-0");
            }, TOOLTIP_DURATION_MS);
          }

          const liveRegion =
            button.closest(".share-buttons")?.nextElementSibling;
          if (liveRegion && liveRegion.getAttribute("role") === "status") {
            liveRegion.textContent = "URLをコピーしました";
            setTimeout(() => {
              liveRegion.textContent = "";
            }, TOOLTIP_DURATION_MS);
          }
        } catch (error) {
          console.error("Failed to copy URL:", error);

          const liveRegion =
            button.closest(".share-buttons")?.nextElementSibling;
          if (liveRegion && liveRegion.getAttribute("role") === "status") {
            liveRegion.textContent = "コピーに失敗しました";
            setTimeout(() => {
              liveRegion.textContent = "";
            }, TOOLTIP_DURATION_MS);
          }
        }
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCopyButtons);
  } else {
    initCopyButtons();
  }

  document.addEventListener("astro:page-load", initCopyButtons);
</script>

<style>
  .share-btn {
    transition-property: transform;
    transition-timing-function: ease-out;
    transition-duration: 150ms;
  }

  .share-btn:hover {
    transform: translateY(-2px);
  }

  .share-btn:active {
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .share-btn {
      transition: none;
    }
    .share-btn:hover {
      transform: none;
    }
    .tooltip,
    .copy-tooltip,
    .default-tooltip {
      transition: none;
    }
    .tooltip,
    .default-tooltip {
      opacity: 1;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
