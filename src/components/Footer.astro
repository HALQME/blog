---
const today = new Date();

const socialLinks = [
  {
    ariaLabel: "GitHubプロフィール",
    href: "https://github.com/HALQME",
    icon: "i-lucide:github",
    name: "GitHub",
  },
  {
    ariaLabel: "Xプロフィール",
    href: "https://x.com/halqme_dev",
    icon: "i-simple-icons:x",
    name: "X",
  },
  {
    ariaLabel: "Zennプロフィール",
    href: "https://zenn.dev/hal227",
    icon: "i-simple-icons:zenn",
    name: "Zenn",
  },
];
---

<footer class="section mt-auto w-full text-center">
  <div class="container-narrow">
    <div class="mb-4 flex justify-center">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn group"
            aria-label={link.ariaLabel}
          >
            <span class={`social-link-icon ${link.icon}`} aria-hidden="true" />
            <span
              class="flex-inline items-center gap-1 text-xs opacity-0 transition-opacity duration-200 group-hover:opacity-100"
              aria-hidden="true"
            >
              {link.name}
              <span class="i-lucide:external-link text-xs" aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>
    <p class="text-caption">
      &copy; {today.getFullYear()} HALQME. All rights reserved.
    </p>
  </div>
</footer>
