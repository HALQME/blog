---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section class="section-border" aria-labelledby="recent-posts-title">
  <div class="flex items-start justify-between select-none">
    <h2 id="recent-posts-title" class="text-headline mb-8 flex items-center gap-3">
      <div class="i-lucide:pen-tool" aria-hidden="true"></div>
      Recent Posts
    </h2>
    <a href="/blog" class="btn-ghost text-sm">
      View all
      <div class="i-lucide:arrow-right" aria-hidden="true"></div>
    </a>
  </div>
  <div class="grid gap-6 md:grid-cols-3">
    {
      posts.map((post) => (
        <article class="group relative">
          <div class="block">
            <h3 class="text-subhead mb-2">
              <a
                href={`/blog/${post.id}/`}
                class="decoration-2 underline-offset-4 group-hover:underline"
              >
                <span class="absolute inset-0 z-10" aria-hidden="true" />
                {post.data.title}
              </a>
            </h3>
            <div class="text-label flex-inline mb-3 items-center">
              <div class="i-lucide:calendar mr-0.5" aria-hidden="true" />
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("ja-JP")}
              </time>
            </div>
            {post.data.tags && post.data.tags.length > 0 && (
              <ul class="relative z-20 flex flex-wrap gap-2">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <li class="text-caption">
                    <div class="i-lucide:tag text-light" aria-hidden="true" />
                    {tag}
                  </li>
                ))}
                {post.data.tags.length > 2 && (
                  <span class="text-caption">+{post.data.tags.length - 2}</span>
                )}
              </ul>
            )}
          </div>
        </article>
      ))
    }
  </div>
</section>
