---
import { getCollection } from "astro:content";

// 表示する投稿数
const SLICE_START = 0;
const MAX_RECENT_POSTS = 3;
const MAX_TAGS_TO_SHOW = 2;

const posts = (await getCollection("blog"))
  .toSorted((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(SLICE_START, MAX_RECENT_POSTS);
---

<section class="section-border" aria-labelledby="recent-posts-title">
  <div class="flex items-center justify-between">
    <h2
      id="recent-posts-title"
      class="text-headline before:content-empty before:i-lucide:pen-tool mb-8 flex items-center gap-3"
    >
      Recent Posts
    </h2>
    <a
      href="/blog"
      class="btn-ghost after:content-empty after:i-lucide:arrow-right text-sm"
    >
      View all
    </a>
  </div>
  <div class="grid gap-6 md:grid-cols-3">
    {
      posts.map((post) => (
        <article class="group relative">
          <div class="block">
            <h3 class="text-subhead mb-2">
              <a
                href={`/blog/${post.id}/`}
                class="decoration-2 underline-offset-4 group-hover:underline"
              >
                <span class="absolute inset-0 z-10" aria-hidden="true" />
                {post.data.title}
              </a>
            </h3>
            <div class="text-label flex-inline before:content-empty before:i-lucide:calendar mb-3 items-center before:mr-0.5">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("ja-JP")}
              </time>
            </div>
            {post.data.tags && post.data.tags.length > 0 && (
              <ul class="flex flex-wrap gap-2">
                {post.data.tags
                  .slice(0, MAX_TAGS_TO_SHOW)
                  .map((tag: string) => (
                    <li class="text-caption text-neutral-500">{tag}</li>
                  ))}
                {post.data.tags.length > MAX_TAGS_TO_SHOW && (
                  <li class="text-caption">
                    +{post.data.tags.length - MAX_TAGS_TO_SHOW}
                  </li>
                )}
              </ul>
            )}
          </div>
        </article>
      ))
    }
  </div>
</section>
